# Midtrans Payment Gateway Configuration
# Get your API keys from https://dashboard.midtrans.com/

# Server Key (for server-side transactions)
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here

# Client Key (for client-side transactions)
MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here

# Environment: 'sandbox' for testing, 'production' for live
MIDTRANS_ENVIRONMENT=sandbox

# Payment Configuration
MIDTRANS_MERCHANT_ID=your_merchant_id_here

# Payment Methods (comma-separated)
# Available: credit_card, bank_transfer, e-wallet, qris, etc.
MIDTRANS_PAYMENT_METHODS=credit_card,bank_transfer,gopay,ovo,qris

# Transaction Configuration
MIDTRANS_TRANSACTION_EXPIRY_TIME=24
MIDTRANS_CURRENCY=IDR

# Notification URL (for payment status updates)
MIDTRANS_NOTIFICATION_URL=https://yourdomain.com/payment/notification

# Redirect URL (after payment completion)
MIDTRANS_REDIRECT_URL=https://yourdomain.com/payment/finish

# 3D Secure Configuration
MIDTRANS_3DS_ENABLED=true

